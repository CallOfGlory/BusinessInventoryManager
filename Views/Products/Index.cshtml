@model IEnumerable<WebApplication2.ViewModels.Products.ProductViewModel>
@{ ViewData["Title"] = "Products"; var currency = ViewBag.CurrencySymbol ?? "$"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-box-seam text-primary me-2"></i>Products</h2>
            <p class="text-muted mb-0">@(ViewBag.BusinessName ?? "Select a business")</p>
        </div>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-2"></i>Add Product</a>
    </div>

    @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["ErrorMessage"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h4 class="mt-3">No Products Yet</h4>
            <p class="text-muted">Add your first product to start tracking inventory.</p>
            <div><a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-2"></i>Add First Product</a></div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>SKU</th>
                            <th>Category</th>
                            <th class="text-end">Purchase</th>
                            <th class="text-end">Sale</th>
                            <th class="text-center">Stock</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><strong>@p.Name</strong><br/><small class="text-muted">@(p.Description?.Length > 40 ? p.Description.Substring(0, 40) + "..." : p.Description)</small></td>
                                <td class="text-muted">@(p.SKU ?? "-")</td>
                                <td>@if (!string.IsNullOrEmpty(p.Category)) { <span class="badge bg-secondary">@p.Category</span> }</td>
                                <td class="text-end">@currency@p.PurchasePrice.ToString("N2")</td>
                                <td class="text-end text-success fw-bold">@currency@p.SalePrice.ToString("N2")</td>
                                <td class="text-center"><span class="badge @(p.IsLowStock ? "bg-danger" : p.Quantity < 20 ? "bg-warning text-dark" : "bg-success")">@p.Quantity</span></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this product?');">
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="row g-3 mt-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center p-3"><h4 class="text-primary mb-1">@Model.Count()</h4><small class="text-muted">Products</small></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center p-3"><h4 class="text-success mb-1">@Model.Sum(p => p.Quantity)</h4><small class="text-muted">Total Items</small></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center p-3"><h4 class="text-info mb-1">@currency@Model.Sum(p => p.PurchasePrice * p.Quantity).ToString("N2")</h4><small class="text-muted">Inventory Cost</small></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center p-3"><h4 class="text-warning mb-1">@currency@Model.Sum(p => (p.SalePrice - p.PurchasePrice) * p.Quantity).ToString("N2")</h4><small class="text-muted">Potential Profit</small></div></div>
        </div>
    }
</div>
