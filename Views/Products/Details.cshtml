@model WebApplication2.ViewModels.Products.ProductViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-box me-2"></i>@Model.Name</h5>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="text-muted small">SKU</label>
                            <p class="mb-0"><code>@Model.SKU</code></p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small">Category</label>
                            <p class="mb-0"><span class="badge bg-secondary">@Model.Category</span></p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small">Supplier</label>
                            <p class="mb-0">@(Model.SupplierName ?? "Not assigned")</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small">Status</label>
                            <p class="mb-0">
                                @if (Model.IsOutOfStock)
                                {
                                    <span class="badge bg-danger">Out of Stock</span>
                                }
                                else if (Model.IsLowStock)
                                {
                                    <span class="badge bg-warning text-dark">Low Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">In Stock</span>
                                }
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title">Pricing Information</h6>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Purchase Price:</span>
                                    <strong>@Model.PurchasePrice.ToString("C")</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Sale Price:</span>
                                    <strong class="text-success">@Model.SalePrice.ToString("C")</strong>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Profit per Unit:</span>
                                    <strong class="@(Model.ProfitPerUnit >= 0 ? "text-success" : "text-danger")">
                                        @Model.ProfitPerUnit.ToString("C")
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>Profit Margin:</span>
                                    <strong>@Model.ProfitMargin.ToString("F1")%</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card text-center">
                            <div class="card-body">
                                <h3 class="mb-0">@Model.Quantity</h3>
                                <small class="text-muted">Current Stock</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center">
                            <div class="card-body">
                                <h3 class="mb-0">@Model.MinStockLevel</h3>
                                <small class="text-muted">Min Stock Level</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center bg-success text-white">
                            <div class="card-body">
                                <h3 class="mb-0">@Model.TotalProfit.ToString("C")</h3>
                                <small>Potential Profit</small>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <label class="text-muted small">Description</label>
                    <p class="mb-0">@Model.Description</p>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted">Created: @Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</small>
                    </div>
                    <div class="col-md-6 text-md-end">
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <small class="text-muted">Updated: @Model.UpdatedAt.Value.ToString("MMMM dd, yyyy HH:mm")</small>
                        }
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to Products
                </a>
                <div>
                    <a asp-controller="Transactions" asp-action="Create" asp-route-productId="@Model.Id" asp-route-type="1" class="btn btn-success">
                        <i class="bi bi-cart-plus me-1"></i> Record Sale
                    </a>
                    <a asp-controller="Transactions" asp-action="Create" asp-route-productId="@Model.Id" asp-route-type="0" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-down me-1"></i> Record Purchase
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
