@model WebApplication2.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1">Dashboard</h2>
            <p class="text-muted mb-0">@Model.BusinessName - Overview</p>
        </div>
        <div>
            <a asp-controller="Transactions" asp-action="Create" asp-route-type="1" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> New Sale
            </a>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Today's Revenue</p>
                        <h3 class="mb-0">@Model.TodayRevenue.ToString("C")</h3>
                        <small class="text-muted">@Model.TodaySalesCount sales</small>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 align-self-start">
                        <i class="bi bi-currency-dollar text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Monthly Revenue</p>
                        <h3 class="mb-0">@Model.MonthRevenue.ToString("C")</h3>
                        @if (Model.RevenueChangePercent != 0)
                        {
                            <small class="@(Model.RevenueChangePercent >= 0 ? "text-success" : "text-danger")">
                                <i class="bi @(Model.RevenueChangePercent >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>
                                @Math.Abs(Model.RevenueChangePercent).ToString("F1")% vs last month
                            </small>
                        }
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-circle p-3 align-self-start">
                        <i class="bi bi-graph-up-arrow text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Monthly Profit</p>
                        <h3 class="mb-0 @(Model.MonthProfit >= 0 ? "text-success" : "text-danger")">
                            @Model.MonthProfit.ToString("C")
                        </h3>
                        <small class="text-muted">Net profit</small>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-circle p-3 align-self-start">
                        <i class="bi bi-wallet2 text-info fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted small mb-1">Inventory Alerts</p>
                        <h3 class="mb-0">@(Model.LowStockCount + Model.OutOfStockCount)</h3>
                        <small class="text-danger">@Model.OutOfStockCount out of stock</small>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3 align-self-start">
                        <i class="bi bi-exclamation-triangle text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Recent Transactions -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-2"></i>Recent Activity</span>
                <a asp-controller="Transactions" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentTransactions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Type</th>
                                    <th>Qty</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var transaction in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@transaction.ProductName</td>
                                        <td>
                                            @switch (transaction.Type)
                                            {
                                                case WebApplication2.Models.TransactionType.Sale:
                                                    <span class="badge bg-success">Sale</span>
                                                    break;
                                                case WebApplication2.Models.TransactionType.Purchase:
                                                    <span class="badge bg-primary">Purchase</span>
                                                    break;
                                                case WebApplication2.Models.TransactionType.Return:
                                                    <span class="badge bg-warning">Return</span>
                                                    break;
                                                case WebApplication2.Models.TransactionType.WriteOff:
                                                    <span class="badge bg-danger">Write Off</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@transaction.Type</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@transaction.Quantity</td>
                                        <td>@transaction.TotalAmount.ToString("C")</td>
                                        <td class="text-muted">@transaction.TransactionDate.ToString("MMM dd, HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">No recent transactions</p>
                        <a asp-controller="Transactions" asp-action="Create" class="btn btn-primary btn-sm">Record First Transaction</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Low Stock Alert -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-triangle me-2"></i>Low Stock Alerts</span>
                <span class="badge bg-danger">@Model.LowStockProducts.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.LowStockProducts.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var product in Model.LowStockProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-medium">@product.ProductName</div>
                                    <small class="text-muted">Min: @product.MinStockLevel</small>
                                </div>
                                <span class="badge @(product.CurrentStock == 0 ? "bg-danger" : "bg-warning")">
                                    @product.CurrentStock in stock
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">All products well stocked</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Top Products and Category Breakdown -->
<div class="row g-3 mt-3">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-trophy me-2"></i>Top Selling Products (This Month)
            </div>
            <div class="card-body p-0">
                @if (Model.TopProducts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Product</th>
                                    <th>Sold</th>
                                    <th>Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopProducts.Count; i++)
                                {
                                    var product = Model.TopProducts[i];
                                    <tr>
                                        <td><span class="badge bg-secondary">@(i + 1)</span></td>
                                        <td>@product.ProductName</td>
                                        <td>@product.QuantitySold</td>
                                        <td class="text-success fw-medium">@product.Revenue.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">No sales data yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pie-chart me-2"></i>Sales by Category
            </div>
            <div class="card-body">
                @if (Model.CategoryBreakdown.Any())
                {
                    @foreach (var category in Model.CategoryBreakdown)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>@category.Category</span>
                                <span class="fw-medium">@category.TotalSales.ToString("C") (@category.Percentage.ToString("F1")%)</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" style="width: @category.Percentage%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">No category data yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
