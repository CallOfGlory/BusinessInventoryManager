@model WebApplication2.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-1">Welcome back, @Model.Username!</h1>
                    <p class="text-muted mb-0">
                        @if (Model.HasActiveBusiness)
                        {
                            <span>Managing <strong>@Model.ActiveBusinessName</strong></span>
                        }
                        else
                        {
                            <span>Select or create a business to get started</span>
                        }
                    </p>
                </div>
                <div>
                    <a asp-controller="Business" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-building me-2"></i>My Businesses (@Model.TotalBusinesses)
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.HasActiveBusiness)
    {
        <!-- No Active Business -->
        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-shop display-1 text-muted mb-4"></i>
                        <h3>No Active Business</h3>
                        <p class="text-muted mb-4">Create a new business or select an existing one to start managing your inventory.</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-controller="Business" asp-action="Create" class="btn btn-primary btn-lg">
                                <i class="bi bi-plus-circle me-2"></i>Create Business
                            </a>
                            <a asp-controller="Business" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-building me-2"></i>View Businesses
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Key Metrics -->
        <div class="row g-4 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                    <i class="bi bi-box-seam text-primary fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Total Products</h6>
                                <h3 class="mb-0">@Model.TotalProducts</h3>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <a asp-controller="Products" asp-action="Index" class="text-decoration-none small">
                            View all products <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                    <i class="bi bi-cash-stack text-success fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Sales This Month</h6>
                                <h3 class="mb-0">@Model.CurrencySymbol@Model.TotalSalesThisMonth.ToString("N2")</h3>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <span class="text-muted small">
                            Today: @Model.CurrencySymbol@Model.TotalSalesToday.ToString("N2")
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-info bg-opacity-10 rounded-circle p-3">
                                    <i class="bi bi-graph-up-arrow text-info fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Profit This Month</h6>
                                <h3 class="mb-0 @(Model.ProfitThisMonth >= 0 ? "text-success" : "text-danger")">
                                    @Model.CurrencySymbol@Model.ProfitThisMonth.ToString("N2")
                                </h3>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <a asp-controller="Analytics" asp-action="Index" class="text-decoration-none small">
                            View analytics <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                                    <i class="bi bi-archive text-warning fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Inventory Value</h6>
                                <h3 class="mb-0">@Model.CurrencySymbol@Model.TotalInventoryValue.ToString("N2")</h3>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <span class="text-muted small">
                            @Model.TransactionsThisMonth transactions this month
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Recent Transactions -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-clock-history me-2"></i>Recent Transactions
                        </h5>
                        <a asp-controller="Transactions" asp-action="Index" class="btn btn-sm btn-outline-primary">
                            View All
                        </a>
                    </div>
                    <div class="card-body p-0">
                        @if (!Model.RecentTransactions.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-inbox text-muted display-4"></i>
                                <p class="text-muted mt-3">No transactions yet</p>
                                <a asp-controller="Transactions" asp-action="Create" class="btn btn-primary">
                                    <i class="bi bi-plus-circle me-2"></i>Record Transaction
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Product</th>
                                            <th>Type</th>
                                            <th>Quantity</th>
                                            <th>Amount</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var transaction in Model.RecentTransactions)
                                        {
                                            <tr>
                                                <td class="fw-medium">@transaction.ProductName</td>
                                                <td>
                                                    @if (transaction.Type == "Sale")
                                                    {
                                                        <span class="badge bg-success">Sale</span>
                                                    }
                                                    else if (transaction.Type == "Purchase")
                                                    {
                                                        <span class="badge bg-primary">Purchase</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Adjustment</span>
                                                    }
                                                </td>
                                                <td>@transaction.Quantity</td>
                                                <td>@Model.CurrencySymbol@transaction.TotalAmount.ToString("N2")</td>
                                                <td class="text-muted">@transaction.TransactionDate.ToString("MMM dd, HH:mm")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Low Stock Alerts -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-exclamation-triangle text-warning me-2"></i>Low Stock Alerts
                            @if (Model.LowStockProducts > 0)
                            {
                                <span class="badge bg-danger ms-2">@Model.LowStockProducts</span>
                            }
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (!Model.LowStockItems.Any())
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-check-circle text-success display-4"></i>
                                <p class="text-muted mt-3 mb-0">All products are well stocked!</p>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.LowStockItems)
                                {
                                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-0">@item.Name</h6>
                                            <small class="text-muted">@item.Category</small>
                                        </div>
                                        <span class="badge bg-danger">@item.Quantity left</span>
                                    </div>
                                }
                            </div>
                            <div class="mt-3">
                                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-warning w-100">
                                    <i class="bi bi-box-seam me-2"></i>Manage Inventory
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3 col-6">
                                <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary w-100 py-3">
                                    <i class="bi bi-plus-circle d-block mb-2 fs-4"></i>
                                    Add Product
                                </a>
                            </div>
                            <div class="col-md-3 col-6">
                                <a asp-controller="Transactions" asp-action="Create" class="btn btn-outline-success w-100 py-3">
                                    <i class="bi bi-arrow-left-right d-block mb-2 fs-4"></i>
                                    Record Transaction
                                </a>
                            </div>
                            <div class="col-md-3 col-6">
                                <a asp-controller="Analytics" asp-action="Index" class="btn btn-outline-info w-100 py-3">
                                    <i class="bi bi-graph-up d-block mb-2 fs-4"></i>
                                    View Analytics
                                </a>
                            </div>
                            <div class="col-md-3 col-6">
                                <a asp-controller="Business" asp-action="Index" class="btn btn-outline-secondary w-100 py-3">
                                    <i class="bi bi-building d-block mb-2 fs-4"></i>
                                    Switch Business
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .card {
            border-radius: 12px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.08) !important;
        }
        .btn-outline-primary:hover, .btn-outline-success:hover, 
        .btn-outline-info:hover, .btn-outline-secondary:hover {
            transform: translateY(-2px);
        }
    </style>
}
