@model WebApplication2.ViewModels.Profile.ProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person me-2"></i>My Profile</h5>
            </div>
            <div class="card-body">
                <form asp-action="Update" method="post">
                    <div class="row mb-4">
                        <div class="col-md-3 text-center">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                <i class="bi bi-person text-primary" style="font-size: 3rem;"></i>
                            </div>
                            <p class="text-muted small mt-2">@Model.Email</p>
                        </div>
                        <div class="col-md-9">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <input type="text" asp-for="FirstName" class="form-control" placeholder="Enter first name" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" asp-for="LastName" class="form-control" placeholder="Enter last name" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Username</label>
                                    <input type="text" asp-for="Username" class="form-control" />
                                    <span asp-validation-for="Username" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <input type="tel" asp-for="Phone" class="form-control" placeholder="+1 234 567 8900" />
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Email</label>
                                    <input type="email" asp-for="Email" class="form-control" readonly />
                                    <small class="text-muted">Email cannot be changed</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Member Since</p>
                            <p class="mb-0">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Last Login</p>
                            <p class="mb-0">@(Model.LastLoginAt?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")</p>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="row g-3 mt-3">
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h4 class="text-primary mb-0">@Model.TotalBusinesses</h4>
                        <small class="text-muted">Businesses</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h4 class="text-success mb-0">@Model.TotalProducts</h4>
                        <small class="text-muted">Products</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h4 class="text-info mb-0">@Model.TotalTransactions</h4>
                        <small class="text-muted">Transactions</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Script {
    <partial name="_ValidationScriptsPartial" />
}
