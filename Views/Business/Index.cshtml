@model IEnumerable<WebApplication2.ViewModels.Business.BusinessViewModel>

@{
    ViewData["Title"] = "My Businesses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">My Businesses</h2>
        <p class="text-muted mb-0">Manage your business accounts</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Business
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-building text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3">No Businesses Yet</h4>
            <p class="text-muted">Create your first business to start managing inventory</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Create Business
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var business in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(business.IsActive ? "border-primary" : "")">
                    @if (business.IsActive)
                    {
                        <div class="card-header bg-primary text-white">
                            <i class="bi bi-check-circle me-1"></i> Active Business
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@business.Name</h5>
                        <p class="card-text text-muted small">@(string.IsNullOrEmpty(business.Description) ? "No description" : business.Description)</p>
                        
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="bg-light rounded p-2 text-center">
                                    <div class="small text-muted">Products</div>
                                    <div class="fw-bold">@business.ProductCount</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-2 text-center">
                                    <div class="small text-muted">Transactions</div>
                                    <div class="fw-bold">@business.TransactionCount</div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mb-2">
                            <span class="badge bg-secondary">@business.Currency</span>
                            @if (!string.IsNullOrEmpty(business.Phone))
                            {
                                <span class="badge bg-light text-dark"><i class="bi bi-telephone"></i> @business.Phone</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">Created @business.CreatedAt.ToString("MMM dd, yyyy")</small>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                    Actions
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (!business.IsActive)
                                    {
                                        <li>
                                            <form asp-action="SetActive" asp-route-id="@business.Id" method="post">
                                                <button type="submit" class="dropdown-item">
                                                    <i class="bi bi-check-circle me-2"></i>Set as Active
                                                </button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@business.Id">
                                            <i class="bi bi-pencil me-2"></i>Edit
                                        </a>
                                    </li>
                                    <li>
                                        <button class="dropdown-item text-danger" onclick="confirmDelete(@business.Id, '@business.Name')">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Business</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="businessName"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle"></i> This will delete all products and transactions!</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="businessId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('businessId').value = id;
            document.getElementById('businessName').textContent = name;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
