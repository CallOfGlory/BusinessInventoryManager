@model WebApplication2.ViewModels.Business.BusinessViewModel

@{
    ViewData["Title"] = Model.Name + " - Details";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">My Businesses</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-building me-2"></i>@Model.Name
                    </h4>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle me-1"></i>Active
                        </span>
                    }
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-muted">@Model.Description</p>
                    }

                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                    <i class="bi bi-currency-exchange text-primary fs-4"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Currency</small>
                                    <strong>@Model.Currency (@Model.CurrencySymbol)</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                    <i class="bi bi-calendar3 text-info fs-4"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Created</small>
                                    <strong>@Model.CreatedAt.ToString("MMMM dd, yyyy")</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-box-seam d-block mb-2 fs-4"></i>
                                View Products
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a asp-controller="Transactions" asp-action="Index" class="btn btn-outline-success w-100 py-3">
                                <i class="bi bi-arrow-left-right d-block mb-2 fs-4"></i>
                                View Transactions
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a asp-controller="Analytics" asp-action="Index" class="btn btn-outline-info w-100 py-3">
                                <i class="bi bi-graph-up d-block mb-2 fs-4"></i>
                                View Analytics
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Statistics -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Total Products</span>
                            <span class="badge bg-primary fs-6">@Model.ProductCount</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-primary" style="width: @(Math.Min(Model.ProductCount * 5, 100))%"></div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Total Transactions</span>
                            <span class="badge bg-success fs-6">@Model.TransactionCount</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: @(Math.Min(Model.TransactionCount, 100))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Inventory Value</span>
                            <span class="badge bg-info fs-6">@Model.CurrencySymbol@Model.TotalInventoryValue.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Manage</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                            <i class="bi bi-pencil me-2"></i>Edit Business
                        </a>
                        @if (!Model.IsActive)
                        {
                            <form asp-action="SetActive" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="bi bi-check-circle me-2"></i>Set as Active
                                </button>
                            </form>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to Businesses
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
