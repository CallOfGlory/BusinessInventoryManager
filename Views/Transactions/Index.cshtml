@model WebApplication2.ViewModels.Transactions.TransactionListViewModel

@{
    ViewData["Title"] = "Transactions";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Transactions</h1>
            <p class="text-muted mb-0">Activity log for <strong>@Model.BusinessName</strong></p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Record Transaction
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <h6 class="text-white-50">Total Transactions</h6>
                    <h3 class="mb-0">@Model.TotalTransactions</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body">
                    <h6 class="text-white-50">Total Sales</h6>
                    <h3 class="mb-0">@Model.CurrencySymbol@Model.TotalSales.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body">
                    <h6 class="text-white-50">Total Purchases</h6>
                    <h3 class="mb-0">@Model.CurrencySymbol@Model.TotalPurchases.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" 
                           value="@Model.FilterStartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" 
                           value="@Model.FilterEndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select name="type" class="form-select">
                        <option value="">All Types</option>
                        <option value="Sale" selected="@(Model.FilterType == "Sale")">Sales</option>
                        <option value="Purchase" selected="@(Model.FilterType == "Purchase")">Purchases</option>
                        <option value="Adjustment" selected="@(Model.FilterType == "Adjustment")">Adjustments</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-filter me-1"></i>Filter
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Transactions.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <h4 class="mt-3">No Transactions Found</h4>
                    <p class="text-muted">No transactions match your filter criteria.</p>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Record Your First Transaction
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date & Time</th>
                                <th>Product</th>
                                <th>Type</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                                <th>Notes</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in Model.Transactions)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-medium">@transaction.TransactionDate.ToString("MMM dd, yyyy")</div>
                                        <small class="text-muted">@transaction.TransactionDate.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@transaction.ProductId" 
                                           class="text-decoration-none">
                                            @transaction.ProductName
                                        </a>
                                    </td>
                                    <td>
                                        @switch (transaction.Type)
                                        {
                                            case WebApplication2.Models.TransactionType.Sale:
                                                <span class="badge bg-success">
                                                    <i class="bi bi-arrow-up-right me-1"></i>Sale
                                                </span>
                                                break;
                                            case WebApplication2.Models.TransactionType.Purchase:
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-arrow-down-left me-1"></i>Purchase
                                                </span>
                                                break;
                                            case WebApplication2.Models.TransactionType.Adjustment:
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-sliders me-1"></i>Adjustment
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (transaction.Type == WebApplication2.Models.TransactionType.Purchase)
                                        {
                                            <span class="text-success">+@transaction.Quantity</span>
                                        }
                                        else if (transaction.Type == WebApplication2.Models.TransactionType.Sale)
                                        {
                                            <span class="text-danger">-@transaction.Quantity</span>
                                        }
                                        else
                                        {
                                            <span>@transaction.Quantity</span>
                                        }
                                    </td>
                                    <td>@Model.CurrencySymbol@transaction.UnitPrice.ToString("N2")</td>
                                    <td class="fw-bold">@Model.CurrencySymbol@transaction.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(transaction.Notes))
                                        {
                                            <span class="text-muted small" title="@transaction.Notes">
                                                @(transaction.Notes.Length > 30 ? transaction.Notes.Substring(0, 30) + "..." : transaction.Notes)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@transaction.Id" 
                                               class="btn btn-outline-primary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger" 
                                                    onclick="confirmDelete(@transaction.Id, '@transaction.ProductName')"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this transaction for <strong id="transactionProduct"></strong>?</p>
                <p class="text-warning small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Note: This will NOT reverse the stock changes made by this transaction.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="transactionId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script>
        function confirmDelete(transactionId, productName) {
            document.getElementById('transactionId').value = transactionId;
            document.getElementById('transactionProduct').textContent = productName;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }
    </script>
}

@section Styles {
    <style>
        .card {
            border-radius: 12px;
        }
        .table th {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
}
