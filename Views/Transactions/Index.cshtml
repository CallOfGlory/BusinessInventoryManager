@model WebApplication2.ViewModels.Transactions.TransactionListViewModel

@{
    ViewData["Title"] = "Activity";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Activity</h2>
        <p class="text-muted mb-0">@ViewBag.BusinessName - Transaction History</p>
    </div>
    <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-plus-lg"></i> New Transaction
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-action="Create" asp-route-type="1"><i class="bi bi-cash me-2"></i>Sale</a></li>
            <li><a class="dropdown-item" asp-action="Create" asp-route-type="0"><i class="bi bi-cart me-2"></i>Purchase</a></li>
            <li><a class="dropdown-item" asp-action="Create" asp-route-type="2"><i class="bi bi-arrow-return-left me-2"></i>Return</a></li>
            <li><a class="dropdown-item" asp-action="Create" asp-route-type="4"><i class="bi bi-x-circle me-2"></i>Write Off</a></li>
        </ul>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <div class="small opacity-75">Total Sales</div>
                <div class="fs-4 fw-bold">@Model.TotalSales.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <div class="small opacity-75">Total Purchases</div>
                <div class="fs-4 fw-bold">@Model.TotalPurchases.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card @(Model.NetProfit >= 0 ? "bg-info" : "bg-danger") text-white">
            <div class="card-body">
                <div class="small opacity-75">Net Profit</div>
                <div class="fs-4 fw-bold">@Model.NetProfit.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white">
            <div class="card-body">
                <div class="small opacity-75">Transactions</div>
                <div class="fs-4 fw-bold">@Model.TotalTransactions</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Start Date</label>
                <input type="date" name="startDate" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">End Date</label>
                <input type="date" name="endDate" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Type</label>
                <select name="type" class="form-select">
                    <option value="">All Types</option>
                    <option value="0" @(Model.FilterType == WebApplication2.Models.TransactionType.Purchase ? "selected" : "")>Purchase</option>
                    <option value="1" @(Model.FilterType == WebApplication2.Models.TransactionType.Sale ? "selected" : "")>Sale</option>
                    <option value="2" @(Model.FilterType == WebApplication2.Models.TransactionType.Return ? "selected" : "")>Return</option>
                    <option value="4" @(Model.FilterType == WebApplication2.Models.TransactionType.WriteOff ? "selected" : "")>Write Off</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Transactions Table -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Transactions.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>Type</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                            <th>Notes</th>
                            <th width="100"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model.Transactions)
                        {
                            <tr>
                                <td>
                                    <div>@transaction.TransactionDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@transaction.TransactionDate.ToString("HH:mm")</small>
                                </td>
                                <td class="fw-medium">@transaction.ProductName</td>
                                <td>
                                    @switch (transaction.Type)
                                    {
                                        case WebApplication2.Models.TransactionType.Sale:
                                            <span class="badge bg-success"><i class="bi bi-arrow-up"></i> Sale</span>
                                            break;
                                        case WebApplication2.Models.TransactionType.Purchase:
                                            <span class="badge bg-primary"><i class="bi bi-arrow-down"></i> Purchase</span>
                                            break;
                                        case WebApplication2.Models.TransactionType.Return:
                                            <span class="badge bg-warning text-dark"><i class="bi bi-arrow-return-left"></i> Return</span>
                                            break;
                                        case WebApplication2.Models.TransactionType.WriteOff:
                                            <span class="badge bg-danger"><i class="bi bi-x"></i> Write Off</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@transaction.Type</span>
                                            break;
                                    }
                                </td>
                                <td>@transaction.Quantity</td>
                                <td>@transaction.UnitPrice.ToString("C")</td>
                                <td class="fw-medium @(transaction.Type == WebApplication2.Models.TransactionType.Sale ? "text-success" : "")">
                                    @transaction.TotalAmount.ToString("C")
                                </td>
                                <td class="text-muted small">@(string.IsNullOrEmpty(transaction.Notes) ? "-" : transaction.Notes)</td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-link" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" asp-action="Edit" asp-route-id="@transaction.Id">
                                                    <i class="bi bi-pencil me-2"></i>Edit
                                                </a>
                                            </li>
                                            <li>
                                                <button class="dropdown-item text-danger" onclick="confirmDelete(@transaction.Id)">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Transactions Found</h4>
                <p class="text-muted">Record your first transaction to start tracking</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Add Transaction
                </a>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this transaction?</p>
                <p class="text-warning"><i class="bi bi-exclamation-triangle"></i> This will also reverse the stock changes.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="transactionId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script>
        function confirmDelete(id) {
            document.getElementById('transactionId').value = id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
