@model WebApplication2.ViewModels.Transactions.CreateTransactionViewModel

@{
    ViewData["Title"] = "Record Transaction";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white border-0">
                    <h4 class="mb-0">
                        <i class="bi bi-arrow-left-right me-2"></i>Record Transaction
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Transaction Type Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Transaction Type</label>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <input type="radio" class="btn-check" name="Type" id="typeSale" 
                                           value="@((int)WebApplication2.Models.TransactionType.Sale)" autocomplete="off">
                                    <label class="btn btn-outline-success w-100 py-3" for="typeSale">
                                        <i class="bi bi-arrow-up-right d-block fs-4 mb-1"></i>
                                        <strong>Sale</strong>
                                        <small class="d-block text-muted">Decrease stock</small>
                                    </label>
                                </div>
                                <div class="col-md-4">
                                    <input type="radio" class="btn-check" name="Type" id="typePurchase" 
                                           value="@((int)WebApplication2.Models.TransactionType.Purchase)" autocomplete="off" checked>
                                    <label class="btn btn-outline-primary w-100 py-3" for="typePurchase">
                                        <i class="bi bi-arrow-down-left d-block fs-4 mb-1"></i>
                                        <strong>Purchase</strong>
                                        <small class="d-block text-muted">Increase stock</small>
                                    </label>
                                </div>
                                <div class="col-md-4">
                                    <input type="radio" class="btn-check" name="Type" id="typeAdjustment" 
                                           value="@((int)WebApplication2.Models.TransactionType.Adjustment)" autocomplete="off">
                                    <label class="btn btn-outline-secondary w-100 py-3" for="typeAdjustment">
                                        <i class="bi bi-sliders d-block fs-4 mb-1"></i>
                                        <strong>Adjustment</strong>
                                        <small class="d-block text-muted">Correct stock</small>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        <!-- Product Selection -->
                        <div class="mb-4">
                            <label asp-for="ProductId" class="form-label fw-semibold">
                                <i class="bi bi-box me-1"></i>Select Product
                            </label>
                            <select asp-for="ProductId" asp-items="Model.Products" class="form-select form-select-lg" id="productSelect">
                                <option value="">-- Select a product --</option>
                            </select>
                            <span asp-validation-for="ProductId" class="text-danger small"></span>
                        </div>

                        <!-- Product Info Card (shown when product selected) -->
                        <div id="productInfo" class="alert alert-info mb-4" style="display: none;">
                            <div class="row">
                                <div class="col-md-4">
                                    <small class="text-muted">Current Stock</small>
                                    <div class="fw-bold" id="productStock">-</div>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted">Purchase Price</small>
                                    <div class="fw-bold" id="productPurchasePrice">-</div>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted">Sale Price</small>
                                    <div class="fw-bold" id="productSalePrice">-</div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Quantity" class="form-label fw-semibold">
                                    <i class="bi bi-123 me-1"></i>Quantity
                                </label>
                                <input asp-for="Quantity" type="number" min="1" class="form-control form-control-lg" 
                                       id="quantityInput" placeholder="Enter quantity" />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="UnitPrice" class="form-label fw-semibold">
                                    <i class="bi bi-currency-dollar me-1"></i>Unit Price (@Model.CurrencySymbol)
                                </label>
                                <input asp-for="UnitPrice" type="number" step="0.01" min="0.01" 
                                       class="form-control form-control-lg" id="priceInput" placeholder="0.00" />
                                <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Total Amount Preview -->
                        <div class="alert alert-secondary mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">Total Amount:</span>
                                <span class="fs-4 fw-bold" id="totalAmount">@Model.CurrencySymbol 0.00</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">
                                <i class="bi bi-sticky me-1"></i>Notes (Optional)
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="3" 
                                      placeholder="Add any additional notes about this transaction..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="bi bi-check-circle me-2"></i>Record Transaction
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Script {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currencySymbol = '@Model.CurrencySymbol';
        
        // Product selection handler
        document.getElementById('productSelect').addEventListener('change', async function() {
            const productId = this.value;
            const productInfo = document.getElementById('productInfo');
            
            if (!productId) {
                productInfo.style.display = 'none';
                return;
            }

            try {
                const response = await fetch(`/Transactions/GetProductDetails?productId=${productId}`);
                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('productStock').textContent = data.currentStock + ' units';
                    document.getElementById('productPurchasePrice').textContent = currencySymbol + data.purchasePrice.toFixed(2);
                    document.getElementById('productSalePrice').textContent = currencySymbol + data.salePrice.toFixed(2);
                    productInfo.style.display = 'block';

                    // Auto-fill price based on transaction type
                    updatePriceBasedOnType(data);
                }
            } catch (error) {
                console.error('Error fetching product details:', error);
            }
        });

        // Transaction type change handler
        document.querySelectorAll('input[name="Type"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const productSelect = document.getElementById('productSelect');
                if (productSelect.value) {
                    productSelect.dispatchEvent(new Event('change'));
                }
            });
        });

        function updatePriceBasedOnType(productData) {
            const saleRadio = document.getElementById('typeSale');
            const priceInput = document.getElementById('priceInput');
            
            if (saleRadio.checked) {
                priceInput.value = productData.salePrice.toFixed(2);
            } else {
                priceInput.value = productData.purchasePrice.toFixed(2);
            }
            calculateTotal();
        }

        // Calculate total amount
        function calculateTotal() {
            const quantity = parseFloat(document.getElementById('quantityInput').value) || 0;
            const price = parseFloat(document.getElementById('priceInput').value) || 0;
            const total = quantity * price;
            document.getElementById('totalAmount').textContent = currencySymbol + ' ' + total.toFixed(2);
        }

        document.getElementById('quantityInput').addEventListener('input', calculateTotal);
        document.getElementById('priceInput').addEventListener('input', calculateTotal);
    </script>
}

@section Styles {
    <style>
        .btn-check:checked + .btn-outline-success {
            background-color: var(--bs-success);
            color: white;
        }
        .btn-check:checked + .btn-outline-primary {
            background-color: var(--bs-primary);
            color: white;
        }
        .btn-check:checked + .btn-outline-secondary {
            background-color: var(--bs-secondary);
            color: white;
        }
        .btn-check:checked + .btn small {
            color: rgba(255,255,255,0.8) !important;
        }
    </style>
}
