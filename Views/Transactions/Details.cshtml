@model WebApplication2.ViewModels.Transactions.TransactionDetailsViewModel

@{
    ViewData["Title"] = "Transaction Details";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Transactions</a></li>
            <li class="breadcrumb-item active">Transaction #@Model.Id</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-receipt me-2"></i>Transaction Details
                    </h4>
                    @switch (Model.TransactionType)
                    {
                        case "Sale":
                            <span class="badge bg-success fs-6">Sale</span>
                            break;
                        case "Purchase":
                            <span class="badge bg-primary fs-6">Purchase</span>
                            break;
                        default:
                            <span class="badge bg-secondary fs-6">Adjustment</span>
                            break;
                    }
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="mb-4">
                                <label class="text-muted small">Product</label>
                                <div class="fw-bold fs-5">
                                    <a asp-controller="Products" asp-action="Edit" asp-route-id="@Model.ProductId" 
                                       class="text-decoration-none">
                                        @Model.ProductName
                                    </a>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="text-muted small">Quantity</label>
                                <div class="fw-bold fs-5">@Model.Quantity units</div>
                            </div>
                            <div class="mb-4">
                                <label class="text-muted small">Unit Price</label>
                                <div class="fw-bold fs-5">@Model.CurrencySymbol@Model.UnitPrice.ToString("N2")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-4">
                                <label class="text-muted small">Transaction Date</label>
                                <div class="fw-bold fs-5">@Model.TransactionDate.ToString("MMMM dd, yyyy")</div>
                                <small class="text-muted">at @Model.TransactionDate.ToString("HH:mm")</small>
                            </div>
                            <div class="mb-4">
                                <label class="text-muted small">Created At</label>
                                <div>@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-12">
                            <div class="bg-light rounded p-4 text-center">
                                <label class="text-muted">Total Amount</label>
                                <div class="display-5 fw-bold text-primary">
                                    @Model.CurrencySymbol@Model.TotalAmount.ToString("N2")
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr />
                        <div>
                            <label class="text-muted small">Notes</label>
                            <p class="mb-0">@Model.Notes</p>
                        </div>
                    }
                </div>
                <div class="card-footer bg-transparent border-0">
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">
                            <i class="bi bi-arrow-left me-2"></i>Back to Transactions
                        </a>
                        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="bi bi-trash me-2"></i>Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this transaction?</p>
                <p class="text-warning small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    This action cannot be undone and will NOT reverse stock changes.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
