@model WebApplication2.ViewModels.Transactions.TransactionViewModel

@{
    ViewData["Title"] = "Edit Transaction";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Transaction</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label">Transaction Type</label>
                        <select asp-for="Type" asp-items="ViewBag.TransactionTypes" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProductId" class="form-label">Product</label>
                        <select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select"></select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Quantity" class="form-label">Quantity</label>
                            <input asp-for="Quantity" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UnitPrice" class="form-label">Unit Price</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0.01" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TransactionDate" class="form-label">Date</label>
                        <input asp-for="TransactionDate" class="form-control" type="datetime-local" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <partial name="_ValidationScriptsPartial" />
}
